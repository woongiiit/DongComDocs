# 이 파일은 apps/api/.env 에 두세요. API는 항상 apps/api/.env 를 읽습니다(루트에서 npm run dev:api 실행 시에도).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dongcomdocs?schema=public"
JWT_SECRET="change-me-in-production-min-32-chars"
PORT=4000
# CORS: 프론트(Railway web) 공개 URL. 쉼표로 여러 개 가능.
# CORS_ORIGIN=https://your-web.up.railway.app
# vLLM (로컬 Docker 또는 Cloudflare Tunnel). 끝 슬래시 없음.
# VLLM_BASE_URL=https://xxxx.trycloudflare.com
# vLLM 멀티모달: PDF→이미지 data URI가 컨텍스트를 크게 씀. 400 "exceeds maximum context length" 시 조합으로 줄이기.
# 출력 상한(max_tokens). 기본 8192. (프롬프트+이미지)+이 값이 모델 컨텍스트를 넘으면 400 → 10k급 모델은 4096 등으로 낮춤.
# VLLM_MAX_OUTPUT_TOKENS=12288
# 렌더 스케일(픽맵 배율, 기본 1.5). 템플릿 분석 라우트는 scale=3 + 아래 옵션만 적용.
# VLLM_RENDER_SCALE=1.2
# vLLM 요청에 넣을 PDF 최대 페이지 수(앞쪽부터, 기본 2)
# VLLM_MAX_PDF_PAGES=1
# 렌더 후 픽셀 기준 긴 변 상한(기본 960). 더 줄이면 800~900.
# VLLM_PAGE_MAX_LONG_EDGE_PX=900
# 페이지 이미지 형식: jpeg(권장, 용량↓) | png
# VLLM_PAGE_IMAGE_FORMAT=jpeg
# VLLM_JPEG_QUALITY=75
# 템플릿 분석 시 PDF 텍스트 레이어 후보를 VLM 프롬프트에 주입(기본 on). 끄려면 0
# PDF_TEXT_HINTS=0
# 텍스트 후보 추출에 쓸 최대 페이지 수(기본 8)
# PDF_TEXT_LAYER_MAX_PAGES=8
# 후보 문자열 최대 개수(기본 220)
# PDF_TEXT_HINT_MAX_ITEMS=220
# 템플릿 분석 후 서버 콘솔에 bbox 계산 상세 JSON 로그 (1=true=yes)
# DEBUG_TEMPLATE_BBOX=1
# VLM이 bbox 네 숫자를 [ymin,xmin,ymax,xmax]로만 내는 경우(일부 Qwen 응답): 1로 두면 이 순서를 먼저 해석
# TEMPLATE_BBOX_TRY_YMIN_FIRST=1
# 쉼표로 구분. 관리자로 부여할 학번 (예: 2020123456)
# 올바름: 2020123456,2020987654
ADMIN_ID=2020123456
